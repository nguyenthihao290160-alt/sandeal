{
  "name": "sandeal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "node scripts/test-runner.cjs && node scripts/prompt05b-dashboard-tests.cjs && node scripts/prompt06-automation-tests.cjs && node scripts/prompt07-release-ui-tests.cjs",
    "test:dashboard": "node scripts/prompt05b-dashboard-tests.cjs",
    "test:automation": "node scripts/prompt06-automation-tests.cjs",
    "test:release-ui": "node scripts/prompt07-release-ui-tests.cjs",
    "test:stabilization": "node scripts/stabilization-tests.cjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "node scripts/automation-worker.cjs",
    "scheduler": "node scripts/automation-scheduler.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "release:preflight": "node scripts/release-preflight.cjs",
    "release:preflight:strict": "node scripts/release-preflight.cjs --release",
    "release:secret-scan": "node scripts/release-validation.cjs secret-scan",
    "release:generated-check": "node scripts/release-validation.cjs generated-check",
    "release:migration-check": "node scripts/release-validation.cjs migration-check",
    "release:backup": "node scripts/release-storage.cjs backup",
    "release:backup-verify": "node scripts/release-storage.cjs verify-roundtrip",
    "release:manifest:create": "node scripts/release-manifest.cjs create --test=passed --build=passed --typecheck=passed --secret-scan=passed --backup-restore=passed",
    "release:manifest:validate": "node scripts/release-manifest.cjs validate",
    "release:quality": "npm run typecheck && npm run lint && npm run test:release-ui && npm run test:automation && npm test && npm run build && npm run release:secret-scan && npm run release:generated-check && npm run release:migration-check && npm run release:backup-verify && npm run release:manifest:create && npm run release:manifest:validate",
    "reprocess:v2:dry": "node scripts/reprocess-products-v2.cjs",
    "reprocess:v2:apply": "node scripts/reprocess-products-v2.cjs --apply",
    "smoke:autonomous": "node scripts/autonomous-pipeline-smoke.cjs"
  },
  "engines": {
    "node": ">=20.9.0 <25"
  },
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5"
  }
}
