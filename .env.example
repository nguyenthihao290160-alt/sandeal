# ===========================================
# SanDeal / ReviewPilot AI — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.production with real secrets.

# --- App ---
NEXT_PUBLIC_APP_NAME=SanDeal
NEXT_PUBLIC_ENGINE_NAME=ReviewPilot AI
NEXT_PUBLIC_SITE_URL=https://sandeal.tech

# --- Safe Mode / Cost Control ---
AI_COST_MODE=free_only
ALLOW_PAID_AI=false
ALLOW_VEO_API=false
ALLOW_IMAGE_GENERATION=false
ALLOW_TTS_GENERATION=false
ALLOW_GOOGLE_SEARCH_GROUNDING=false
ALLOW_DEEP_RESEARCH=false
ALLOW_PUBLISHING_API=false
ALLOW_ADS_API=false
AUTO_PUBLISH_ENABLED=false

# --- Basic Auth (Dashboard Protection) ---
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
SCHEDULER_SECRET=

# --- Token Vault Encryption ---
# Used to encrypt/decrypt secrets in Token Vault.
# Generate a random 32+ char string. If not set, base64 fallback is used.
TOKEN_VAULT_SECRET_KEY=change_me_to_a_long_random_secret

# --- AI Providers ---
# Gemini API keys can also be managed via Token Vault UI.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# --- Affiliate Sources ---
# AccessTrade key can also be managed via Token Vault UI.
ACCESS_TRADE_API_KEY=

# --- Social / Publishing (env fallback, prefer Token Vault) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_USER_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
LAZADA_AFFILIATE_APP_KEY=
LAZADA_AFFILIATE_APP_SECRET=
