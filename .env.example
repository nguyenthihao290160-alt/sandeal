# SanDeal environment variable names only. Never place real secrets in this file.

# Web: required before a production release.
NEXT_PUBLIC_SITE_URL=
BASIC_AUTH_ENABLED=
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
TOKEN_VAULT_SECRET_KEY=

# Shared runtime storage: required for web, worker, and scheduler in production.
# Mongo is opt-in only. Never commit a real URI or expose it through NEXT_PUBLIC_*.
# Mongo schema inspection/apply is a separate explicit operation, never a startup action.
SANDEAL_STORAGE_DRIVER=file
SANDEAL_DATA_DIR=
MONGODB_URI=
MONGODB_DATABASE=sandeal
TZ=

# Scheduler administration: required when protected scheduler endpoints are used.
SCHEDULER_SECRET=

# Safety policy: review explicitly before release.
AI_COST_MODE=
ALLOW_PAID_AI=
ALLOW_VEO_API=
ALLOW_IMAGE_GENERATION=
ALLOW_TTS_GENERATION=
ALLOW_GOOGLE_SEARCH_GROUNDING=
ALLOW_DEEP_RESEARCH=
ALLOW_PUBLISHING_API=
ALLOW_ADS_API=
AUTO_PUBLISH_ENABLED=

# Optional branding. The application has local fallback labels.
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_ENGINE_NAME=

# Optional external AI providers. Missing values must not crash the dashboard.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Optional product and affiliate providers.
ACCESS_TRADE_API_KEY=
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
LAZADA_AFFILIATE_APP_KEY=
LAZADA_AFFILIATE_APP_SECRET=

# Optional social and publishing connections. Prefer the encrypted connection vault.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_USER_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
